{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "$client/*": ["./client/*"],
      "$server/*": ["./server/*"],
      "$db/*": ["./db/*"],
      "$lib/*": ["./lib/*"]
    }
  },
  "include": ["**/*.ts"]
}
